# 3D Model with Box and Emissive Plane (Triangulated)
mtllib cornelbox.mtl

# ----------------------------------------
# (1) 直方体の定義
# ----------------------------------------
# 頂点座標 (v 1～8)
v 0.0 0.0 0.0
v 100.0 0.0 0.0
v 100.0 81.6 0.0
v 0.0 81.6 0.0
v 0.0 0.0 170.0
v 100.0 0.0 170.0
v 100.0 81.6 170.0
v 0.0 81.6 170.0

# 面の定義（すべて三角形2枚に分割）

# 左辺の面 (X=0 の面) -> 赤系のマテリアル
g box_left
usemtl mat_box_left
f 1 4 8
f 1 8 5

# 右辺の面 (X=100 の面) -> 青系のマテリアル
g box_right
usemtl mat_box_right
f 2 6 7
f 2 7 3

# Z=170 の面 (天面) -> 黒のマテリアル
g box_top
usemtl mat_box_top
f 5 6 7
f 5 7 8

# その他の面 (底面および前後の面) -> 通常のグレー
g box_other
usemtl mat_box_default
f 1 2 3
f 1 3 4
f 1 5 6
f 1 6 2
f 4 3 7
f 4 7 8

# ----------------------------------------
# (2) 平面の定義 (Y=81 の位置にある発光面)
# ----------------------------------------
# 頂点座標 (v 9～12)
v 30.0 81.0 60.0
v 70.0 81.0 60.0
v 70.0 81.0 100.0
v 30.0 81.0 100.0

g emissive_plane
usemtl mat_emissive
f 9 10 11
f 9 11 12
